# n8n webhook endpoint that receives translation requests.
N8N_WEBHOOK_URL="https://rosily-gung-greta.ngrok-free.dev/webhook/send-message"

# Shared secret for the translation webhook.
N8N_AUTH_TOKEN="abcxyz_2026"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
