# Root web server environment
PORT=3000
NODE_ENV=development

# Optional API proxy from the web server to your separate backend project.
# Keep this enabled for local single-origin development.
USE_TRANSLATION_SERVICE=true
BACKEND_API_URL=http://127.0.0.1:8000

# AI Studio / hosting URL if needed by the SPA runtime.
APP_URL=MY_APP_URL

# Optional override for Vietnamese assist EN->VI provider in Tra cuu popup.
VITE_LABAN_DICTIONARY_URL=https://dict.laban.vn/ajax/autocomplete

# Optional override for Vietnamese-Vietnamese dictionary lookup in translated text pane.
VITE_MINHQND_VI_DICT_URL=https://dict.minhqnd.com/api/v1/lookup
