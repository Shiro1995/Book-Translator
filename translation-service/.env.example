# Translation Service port
PORT=3100

# n8n webhook endpoint
N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook/send-message
N8N_AUTH_TOKEN=your_secret_token_here

# Webhook timeout in milliseconds
N8N_TIMEOUT_MS=120000

# Queue concurrency (how many jobs run in parallel)
QUEUE_CONCURRENCY=2

# Cache TTL in seconds (default 1 hour)
CACHE_TTL_SECONDS=3600

# Max cache entries
CACHE_MAX_SIZE=500

# Rate limit: max requests per window
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Upload size limit
MAX_UPLOAD_SIZE_MB=50

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Node environment
NODE_ENV=production
