# Translation service runtime
PORT=3100
NODE_ENV=development
LOG_LEVEL=info

# Translation provider selection
TRANSLATION_PROVIDER=cliproxy

# Cliproxy / OpenAI-compatible Chat Completions endpoint
# Base URL only. The service appends /v1/chat/completions automatically.
CLIPROXY_BASE_URL=http://69.87.219.202:8317
CLIPROXY_API_KEY=your_api_key_here
# Model comes from FE request body: settings.model
CLIPROXY_TIMEOUT_MS=60000
CLIPROXY_MAX_RETRIES=2

# Queue concurrency
QUEUE_CONCURRENCY=2

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=500

# Rate limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Upload size limit
MAX_UPLOAD_SIZE_MB=50
